---
export const prerender = false;
/**
 * noticias/[slug].astro
 * =====================
 * Convierte los marcadores <!-- AD_SLOT --> del cuerpo en bloques
 * reales de Google AdSense. Cuantos más slots insertó Claude,
 * más ingresos por nota.
 */
import Layout from "../../layouts/BaseHTML.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import Sidebar from "../../components/Sidebar.astro";
import { getArticleBySlug, getRelatedArticles } from "../../lib/api";

const { slug } = Astro.params;
console.log('[slug.astro] Buscando artículo:', slug);
console.log('[slug.astro] API_BASE:', import.meta.env.PUBLIC_API_URL);
const article = await getArticleBySlug(slug);
console.log('[slug.astro] Artículo encontrado:', article ? 'SÍ' : 'NO');

if (!article) {
  return Astro.redirect("/404");
}

const related = await getRelatedArticles(article.slug) ?? [];

// ── AdSense config ─────────────────────────────────────────────────────────
const ADSENSE_PUBLISHER = import.meta.env.PUBLIC_ADSENSE_PUBLISHER_ID;
const AD_SLOT_INCONTENT  = import.meta.env.PUBLIC_ADSENSE_SLOT_INCONTENT  || "";
const AD_SLOT_SIDEBAR    = import.meta.env.PUBLIC_ADSENSE_SLOT_SIDEBAR    || "";
const AD_SLOT_FOOTER     = import.meta.env.PUBLIC_ADSENSE_SLOT_FOOTER     || "";

// ── Replace <!-- AD_SLOT --> with actual AdSense ins tags ──────────────────
function injectAds(html: string): string {
  if (!ADSENSE_PUBLISHER || !AD_SLOT_INCONTENT) {
    // Dev: placeholder visible
    return html.replace(
      /<!-- AD_SLOT -->/g,
      `<div class="ad-placeholder-inline"><span>Publicidad · 320×100</span></div>`
    );
  }
  let n = 0;
  return html.replace(/<!-- AD_SLOT -->/g, () => {
    n++;
    return `<div class="ad-incontent" data-slot-n="${n}">
  <ins class="adsbygoogle"
    style="display:block;text-align:center;"
    data-ad-layout="in-article"
    data-ad-format="fluid"
    data-ad-client="${ADSENSE_PUBLISHER}"
    data-ad-slot="${AD_SLOT_INCONTENT}"></ins>
</div>`;
  });
}

const bodyWithAds = injectAds(article.cuerpo);
const adSlotCount = (article.cuerpo.match(/<!-- AD_SLOT -->/g) || []).length;

// ── Structured data ────────────────────────────────────────────────────────
const sd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "NewsArticle",
  "headline": article.titulo,
  "description": article.bajada,
  "datePublished": article.published_at,
  "dateModified": article.updated_at || article.published_at,
  "author": { "@type": "Organization", "name": "Desde el Tablón" },
  "publisher": { "@type": "Organization", "name": "Desde el Tablón", "url": "https://desdeeltablon.com" },
  "image": article.featured_image?.url,
  "keywords": article.keywords?.join(", "),
});
---

<Layout
  title={`${article.titulo} | Desde el Tablón`}
  description={article.metaDescription || article.bajada}
  canonical={`https://desdeeltablon.com/noticias/${article.slug}`}
>
  <!-- AdSense loader -->
  {ADSENSE_PUBLISHER && (
    <script slot="head" async
      src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${ADSENSE_PUBLISHER}`}
      crossorigin="anonymous" />
  )}
  <script slot="head" type="application/ld+json" set:html={sd} />

  <Header />
  <article class="article-page" data-article-id={article.id}>

    {article.featured_image && !article.featured_image.url.includes('wikipedia.org') && (
      <div class="article-hero">
        <img src={article.featured_image.url} alt={article.titulo}
          width="1200" height="630" loading="eager" fetchpriority="high"
          onerror="this.parentElement.style.display='none'" />
      </div>
    )}

    <div class="article-container">
      <div class="article-main">

        <div class="article-meta-top">
          <span class={`cat-badge cat-${article.categoria}`}>{article.categoria}</span>
          <span class="reading-time">{article.tiempoLectura} min de lectura</span>
          {import.meta.env.DEV && adSlotCount > 0 && (
            <span class="dev-slots">{adSlotCount} ad slots</span>
          )}
        </div>

        <h1 class="article-title">{article.titulo}</h1>
        <p class="article-bajada">{article.bajada}</p>

        <div class="article-byline">
          <div class="author-avatar">DT</div>
          <div>
            <span class="author-name">Redacción Desde el Tablón</span>
            <span class="publish-date">
              {new Date(article.published_at).toLocaleDateString("es-AR", {
                day: "numeric", month: "long", year: "numeric"
              })}
            </span>
          </div>
        </div>

        <!-- Ad before article body -->
        {ADSENSE_PUBLISHER
          ? <ins class="adsbygoogle ad-banner" style="display:block"
              data-ad-client={ADSENSE_PUBLISHER}
              data-ad-slot={AD_SLOT_INCONTENT}
              data-ad-format="auto"
              data-full-width-responsive="true" />
          : <div class="ad-placeholder-banner"><span>Publicidad · 728×90</span></div>
        }

        <!-- Body with injected ad slots -->
        <div class="article-body" set:html={bodyWithAds} />

        <!-- Ad after article body -->
        {ADSENSE_PUBLISHER
          ? <ins class="adsbygoogle ad-banner" style="display:block"
              data-ad-client={ADSENSE_PUBLISHER}
              data-ad-slot={AD_SLOT_FOOTER}
              data-ad-format="auto"
              data-full-width-responsive="true" />
          : <div class="ad-placeholder-banner"><span>Publicidad · 300×250</span></div>
        }

        {article.tags?.length > 0 && (
          <div class="article-tags">
            {article.tags.map((tag: string) => (
              <a href={`/noticias?tag=${encodeURIComponent(tag)}`} class="tag">{tag}</a>
            ))}
          </div>
        )}

        {related.length > 0 && (
          <section class="related-articles">
            <h2>Seguí leyendo</h2>
            <div class="related-grid">
              {related.map((r: any) => (
                <a href={`/noticias/${r.slug}`} class="related-card">
                  {r.featured_image && (
                    <img src={r.featured_image.url} alt={r.titulo} loading="lazy" />
                  )}
                  <div class="related-content">
                    <span class={`cat-badge cat-${r.categoria}`}>{r.categoria}</span>
                    <h3>{r.titulo}</h3>
                    <span class="reading-time">{r.tiempoLectura} min</span>
                  </div>
                </a>
              ))}
            </div>
          </section>
        )}

      </div>

      <!-- Sidebar -->
      <aside class="article-sidebar">
        <!-- Ad slot TOP (antes de próximo partido) -->
        <div class="sidebar-ad-top">
          {ADSENSE_PUBLISHER
            ? <ins class="adsbygoogle" style="display:block"
                data-ad-client={ADSENSE_PUBLISHER}
                data-ad-slot={AD_SLOT_SIDEBAR}
                data-ad-format="auto"
                data-full-width-responsive="true" />
            : <div class="ad-placeholder-sidebar"><span>Publicidad · 300×250</span></div>
          }
        </div>

        <Sidebar />

        <!-- Ad slot BOTTOM (después del sidebar) -->
        <div class="sidebar-ad-bottom">
          {ADSENSE_PUBLISHER
            ? <ins class="adsbygoogle" style="display:block"
                data-ad-client={ADSENSE_PUBLISHER}
                data-ad-slot={AD_SLOT_SIDEBAR}
                data-ad-format="auto"
                data-full-width-responsive="true" />
            : <div class="ad-placeholder-sidebar"><span>Publicidad · 300×600</span></div>
          }
        </div>
      </aside>
    </div>

  </article>
  <Footer />
</Layout>

<script>
  // Initialize all AdSense units after page load
  window.addEventListener("load", () => {
    const units = document.querySelectorAll("ins.adsbygoogle");
    units.forEach(() => {
      try { (window.adsbygoogle = window.adsbygoogle || []).push({}); }
      catch (e) { /* silent */ }
    });
  });

  // Gamification: fire read event at 82% scroll
  const article = document.querySelector(".article-body");
  if (article) {
    const articleId = document.querySelector("[data-article-id]")?.getAttribute("data-article-id");
    let fired = false;
    window.addEventListener("scroll", () => {
      if (fired) return;
      const { scrollTop, scrollHeight, clientHeight } = document.documentElement;
      if ((scrollTop + clientHeight) / scrollHeight >= 0.82) {
        fired = true;
        window.dispatchEvent(new CustomEvent("article:read", { detail: { articleId } }));
      }
    }, { passive: true });
  }
</script>

<style>
  .article-page { max-width: 1280px; margin: 0 auto; }
  .article-hero img { width: 100%; max-height: 480px; object-fit: cover; display: block; }

  .article-container {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 2.5rem;
    padding: 2rem 1.5rem;
    max-width: 1100px;
    margin: 0 auto;
  }
  @media (max-width: 900px) {
    .article-container { grid-template-columns: 1fr; }
    .article-sidebar { display: block; margin-top: 2rem; }
  }

  .article-title {
    font-family: 'Libre Baskerville', Georgia, serif;
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    line-height: 1.2;
    margin: 0.75rem 0;
    color: var(--color-text, #F0EBE3);
  }
  .article-bajada {
    font-family: 'Lora', Georgia, serif;
    font-size: 1.12rem;
    color: var(--color-muted, #7A7470);
    line-height: 1.65;
    font-style: italic;
    margin-bottom: 1.25rem;
  }
  .article-byline {
    display: flex; align-items: center; gap: 0.75rem;
    padding: 1rem 0;
    border-top: 1px solid var(--color-border, #1A1A1A);
    border-bottom: 1px solid var(--color-border, #1A1A1A);
    margin-bottom: 1.5rem;
  }
  .author-avatar {
    width: 34px; height: 34px; border-radius: 50%;
    background: #E63329; color: white;
    font-family: Georgia, serif; font-weight: 700; font-size: 0.72rem;
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  }
  .author-name { display: block; font-size: 0.78rem; font-weight: 600; color: var(--color-text-2, #C0B8B0); font-family: 'DM Sans', sans-serif; }
  .publish-date { font-size: 0.7rem; color: var(--color-faint, #3A3A3A); font-family: 'DM Sans', sans-serif; }

  /* Body */
  .article-body :global(p) {
    font-family: 'Lora', Georgia, serif;
    font-size: 1.1rem; line-height: 1.9;
    color: var(--color-text-2, #C0B8B0);
    margin: 0 0 1.5em;
  }
  .article-body :global(blockquote) {
    border-left: 3px solid #E63329;
    background: var(--color-surface-2, #161616);
    padding: 1rem 1.25rem; margin: 1.75em 0;
    border-radius: 0 8px 8px 0;
    font-family: 'Libre Baskerville', Georgia, serif;
    font-style: italic; font-size: 1.05rem; line-height: 1.6;
    color: var(--color-text, #F0EBE3);
  }
  .article-body :global(strong) { color: var(--color-text, #F0EBE3); font-weight: 700; }

  /* Ad slots injected in body */
  .article-body :global(.ad-incontent) { margin: 2rem 0; min-height: 100px; }
  .article-body :global(.ad-placeholder-inline) {
    display: flex; align-items: center; justify-content: center;
    background: var(--color-ad-bg, #0C0C0C);
    border: 1px solid var(--color-ad-border, #161616);
    border-radius: 6px; min-height: 100px; margin: 2rem 0;
    font-size: 0.58rem; color: var(--color-ad-text, #1C1C1C);
    font-family: sans-serif; letter-spacing: 0.1em; text-transform: uppercase;
  }

  /* Top/bottom banners */
  .ad-banner { margin: 1.5rem 0; min-height: 90px; }
  .ad-placeholder-banner {
    display: flex; align-items: center; justify-content: center;
    background: var(--color-ad-bg, #0C0C0C); border: 1px solid var(--color-ad-border, #161616);
    border-radius: 6px; height: 90px; margin: 1.5rem 0;
    font-size: 0.58rem; color: var(--color-ad-text, #1C1C1C);
    font-family: sans-serif; letter-spacing: 0.1em; text-transform: uppercase;
  }

  /* Sidebar */
  /* Sidebar ad slots */
  .sidebar-ad-top,
  .sidebar-ad-bottom {
    width: 100%;
  }
  .sidebar-ad-bottom {
    margin-top: 1.5rem;
  }
  .sidebar-ad-sticky { position: sticky; top: 1.5rem; }
  .ad-placeholder-sidebar {
    background: #111;
    border: 1px dashed #333;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 120px;
    color: #555;
    font-size: 0.75rem;
    font-family: 'Inter', sans-serif;
  }

  /* Badges + meta */
  .article-meta-top { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.5rem; }
  .cat-badge {
    display: inline-block; font-size: 0.6rem; font-weight: 700;
    letter-spacing: 0.06em; text-transform: uppercase;
    padding: 0.18rem 0.5rem; border-radius: 4px; font-family: 'DM Sans', sans-serif;
  }
  .cat-actualidad  { background: #E6332920; color: #E63329; border: 1px solid #E6332940; }
  .cat-analisis    { background: #3B82F620; color: #3B82F6; border: 1px solid #3B82F640; }
  .cat-historia    { background: #D4A84320; color: #D4A843; border: 1px solid #D4A84340; }
  .cat-mercado     { background: #22C55E20; color: #22C55E; border: 1px solid #22C55E40; }
  .cat-inferiores  { background: #A855F720; color: #A855F7; border: 1px solid #A855F740; }
  .reading-time { font-size: 0.68rem; color: var(--color-faint, #3A3A3A); font-family: 'DM Sans', sans-serif; }
  .dev-slots {
    font-size: 0.58rem; background: #A855F720; color: #A855F7;
    border: 1px solid #A855F740; border-radius: 10px; padding: 0.1rem 0.5rem;
    font-family: 'DM Sans', sans-serif; font-weight: 600;
  }

  /* Tags */
  .article-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; padding-top: 1.5rem; border-top: 1px solid var(--color-border, #1A1A1A); margin-top: 1.5rem; }
  .tag {
    padding: 0.28rem 0.7rem; background: var(--color-surface-2, #161616);
    border: 1px solid var(--color-border-2, #222); border-radius: 20px;
    font-size: 0.68rem; color: var(--color-faint, #3A3A3A); font-family: 'DM Sans', sans-serif;
    text-decoration: none; transition: border-color 0.15s, color 0.15s;
  }
  .tag:hover { border-color: #E63329; color: #E63329; }

  /* Related */
  .related-articles { margin-top: 2.5rem; padding-top: 2rem; border-top: 2px solid var(--color-border, #1A1A1A); }
  .related-articles h2 { font-family: 'Libre Baskerville', Georgia, serif; font-size: 1.1rem; color: var(--color-text, #F0EBE3); margin: 0 0 1rem; }
  .related-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 1rem; }
  .related-card { text-decoration: none; background: var(--color-surface, #111); border: 1px solid var(--color-border, #1A1A1A); border-radius: 10px; overflow: hidden; transition: border-color 0.15s; }
  .related-card:hover { border-color: #E63329; }
  .related-card img { width: 100%; height: 120px; object-fit: cover; display: block; }
  .related-content { padding: 0.75rem; }
  .related-content h3 { font-family: 'Libre Baskerville', Georgia, serif; font-size: 0.85rem; color: var(--color-text, #F0EBE3); margin: 0.4rem 0 0.3rem; line-height: 1.3; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
</style>
