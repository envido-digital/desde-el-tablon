---
import { getArticles } from '../lib/api';

// Resilient: ticker fails silently if API is down
let tickerItems: any[] = [];
try {
  const recentArticles = await getArticles({ limit: 5, categoria: 'actualidad' });
  tickerItems = recentArticles?.articles?.slice(0, 5) ?? [];
} catch { /* ticker is non-critical, fail silently */ }

const navItems = [
  { label: 'Noticias', href: '/noticias' },
  { label: 'Análisis', href: '/noticias?categoria=analisis' },
  { label: 'Historia', href: '/noticias?categoria=historia' },
  { label: 'Mercado', href: '/noticias?categoria=mercado' },
  { label: 'Inferiores', href: '/noticias?categoria=inferiores' },
  { label: 'Tabla', href: '/tabla' },
];

const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <!-- Breaking news ticker -->
  {tickerItems.length > 0 && (
    <div class="ticker-bar">
      <span class="ticker-label">ÚLTIMO</span>
      <div class="ticker-wrapper" aria-live="polite">
        <div class="ticker-track">
          {[...tickerItems, ...tickerItems].map((article, i) => (
            <a href={`/noticias/${article.slug}`} class="ticker-item" key={i}>
              {article.titulo}
              <span class="ticker-sep" aria-hidden="true">·</span>
            </a>
          ))}
        </div>
      </div>
    </div>
  )}

  <!-- Main header -->
  <div class="header-main">
    <div class="header-inner">
      <!-- Logo -->
      <a href="/" class="site-logo" aria-label="Desde el Tablón — Inicio">
        <div class="logo-mark" aria-hidden="true">
          <span class="logo-dt">DT</span>
        </div>
        <div class="logo-text">
          <span class="logo-name">Desde el Tablón</span>
          <span class="logo-tagline">River con memoria</span>
        </div>
      </a>

      <!-- Desktop navigation -->
      <nav class="main-nav" aria-label="Navegación principal">
        {navItems.map(item => (
          <a
            href={item.href}
            class:list={['nav-link', { 'nav-link--active': currentPath === item.href || currentPath.startsWith(item.href + '?') }]}
            aria-current={currentPath === item.href ? 'page' : undefined}
          >
            {item.label}
          </a>
        ))}
      </nav>

      <!-- Actions -->
      <div class="header-actions">
        <button
          id="search-toggle"
          class="btn-icon"
          aria-label="Buscar"
          onclick="document.getElementById('search-overlay').classList.toggle('active')"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
          </svg>
        </button>
        <a href="/mi-cuenta" class="btn-icon" aria-label="Mi cuenta">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
            <circle cx="12" cy="7" r="4"/>
          </svg>
        </a>
        <button id="mobile-menu-toggle" class="btn-icon mobile-only" aria-label="Menú" aria-expanded="false">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M3 12h18M3 6h18M3 18h18"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile nav -->
  <nav id="mobile-nav" class="mobile-nav" aria-label="Menú móvil" aria-hidden="true">
    {navItems.map(item => (
      <a href={item.href} class="mobile-nav-link">{item.label}</a>
    ))}
  </nav>
</header>

<!-- Search overlay -->
<div id="search-overlay" class="search-overlay" role="dialog" aria-modal="true" aria-label="Buscar artículos">
  <div class="search-inner">
    <form action="/noticias" method="get" class="search-form">
      <input
        type="search"
        name="search"
        placeholder="Buscar en Desde el Tablón..."
        class="search-input"
        autofocus
        autocomplete="off"
      />
      <button type="submit" class="search-submit" aria-label="Buscar">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
      </button>
    </form>
    <button
      class="search-close"
      onclick="document.getElementById('search-overlay').classList.remove('active')"
      aria-label="Cerrar búsqueda"
    >
      ✕
    </button>
  </div>
</div>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const mobileNav = document.getElementById('mobile-nav');
  toggle?.addEventListener('click', () => {
    const isOpen = mobileNav?.classList.toggle('mobile-nav--open');
    toggle.setAttribute('aria-expanded', String(isOpen));
    mobileNav?.setAttribute('aria-hidden', String(!isOpen));
  });

  // Close search on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      document.getElementById('search-overlay')?.classList.remove('active');
    }
  });

  // Close search on overlay click
  document.getElementById('search-overlay')?.addEventListener('click', (e) => {
    if ((e.target as HTMLElement).id === 'search-overlay') {
      (e.target as HTMLElement).classList.remove('active');
    }
  });
</script>

<style>
  /* ── Ticker ───────────────────────────────── */
  .ticker-bar {
    background: var(--color-primary);
    color: white;
    display: flex;
    align-items: center;
    overflow: hidden;
    height: 34px;
    font-family: 'Inter', sans-serif;
  }
  .ticker-label {
    flex-shrink: 0;
    background: #7f1d1d;
    padding: 0 16px;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    height: 100%;
    display: flex;
    align-items: center;
  }
  .ticker-wrapper { flex: 1; overflow: hidden; position: relative; }
  .ticker-track {
    display: flex;
    gap: 0;
    animation: ticker 40s linear infinite;
    width: max-content;
  }
  .ticker-item {
    white-space: nowrap;
    font-size: 0.8rem;
    padding: 0 2rem;
    color: white;
    text-decoration: none;
    opacity: 0.95;
    transition: opacity 0.2s;
  }
  .ticker-item:hover { opacity: 1; text-decoration: underline; }
  .ticker-sep { margin: 0 0.5rem; opacity: 0.5; }
  @keyframes ticker {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  .ticker-track:hover,
  .ticker-track:focus-within { animation-play-state: paused; }
  .ticker-item:focus { outline: 2px solid white; outline-offset: -2px; }

  /* ── Main header ─────────────────────────── */
  .header-main {
    background: white;
    border-bottom: 2px solid var(--color-primary);
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
  }
  .header-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 64px;
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  /* ── Logo ────────────────────────────────── */
  .site-logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    flex-shrink: 0;
  }
  .logo-mark {
    width: 42px;
    height: 42px;
    background: var(--color-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 4px;
    flex-shrink: 0;
  }
  .logo-dt {
    color: white;
    font-family: 'Playfair Display', serif;
    font-weight: 900;
    font-size: 1.1rem;
    letter-spacing: -0.02em;
  }
  .logo-text { display: flex; flex-direction: column; line-height: 1.1; }
  .logo-name {
    font-family: 'Playfair Display', serif;
    font-weight: 700;
    font-size: 1.05rem;
    color: var(--color-accent);
    white-space: nowrap;
  }
  .logo-tagline {
    font-size: 0.65rem;
    color: var(--color-text-muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-family: 'Inter', sans-serif;
  }

  /* ── Navigation ──────────────────────────── */
  .main-nav {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    flex: 1;
  }
  .nav-link {
    font-family: 'Inter', sans-serif;
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--color-text-muted);
    text-decoration: none;
    padding: 0.4rem 0.75rem;
    border-radius: 4px;
    transition: all 0.15s;
    white-space: nowrap;
    letter-spacing: 0.01em;
  }
  .nav-link:hover { color: var(--color-primary); background: #fef2f2; }
  .nav-link--active { color: var(--color-primary); font-weight: 600; }

  /* ── Actions ─────────────────────────────── */
  .header-actions { display: flex; align-items: center; gap: 0.25rem; }
  .btn-icon {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    border: none;
    background: transparent;
    color: var(--color-text-muted);
    cursor: pointer;
    transition: all 0.15s;
    text-decoration: none;
  }
  .btn-icon:hover { background: var(--color-surface); color: var(--color-primary); }

  /* ── Mobile nav ──────────────────────────── */
  .mobile-nav {
    display: none;
    flex-direction: column;
    background: white;
    border-top: 1px solid var(--color-border);
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
  }
  .mobile-nav--open { max-height: 400px; display: flex; }
  .mobile-nav-link {
    padding: 0.875rem 1.5rem;
    font-size: 0.95rem;
    color: var(--color-text);
    text-decoration: none;
    border-bottom: 1px solid var(--color-border);
    font-family: 'Inter', sans-serif;
    font-weight: 500;
  }
  .mobile-nav-link:hover { background: var(--color-surface); color: var(--color-primary); }

  /* ── Search overlay ──────────────────────── */
  .search-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.6);
    z-index: 200;
    display: none;
    align-items: flex-start;
    justify-content: center;
    padding-top: 80px;
    backdrop-filter: blur(4px);
  }
  .search-overlay.active { display: flex; }
  .search-inner {
    background: white;
    border-radius: 12px;
    padding: 1.5rem;
    width: 90%;
    max-width: 600px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.3);
    display: flex;
    gap: 0.75rem;
    align-items: center;
  }
  .search-form { flex: 1; display: flex; gap: 0.5rem; }
  .search-input {
    flex: 1;
    border: 2px solid var(--color-border);
    border-radius: 8px;
    padding: 0.75rem 1rem;
    font-size: 1rem;
    font-family: 'Inter', sans-serif;
    outline: none;
    transition: border-color 0.2s;
  }
  .search-input:focus { border-color: var(--color-primary); }
  .search-submit {
    padding: 0.75rem;
    background: var(--color-primary);
    color: white;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    display: flex;
    align-items: center;
    transition: background 0.15s;
  }
  .search-submit:hover { background: var(--color-primary-dark); }
  .search-close {
    background: none;
    border: none;
    font-size: 1.1rem;
    color: var(--color-text-muted);
    cursor: pointer;
    padding: 0.5rem;
    border-radius: 50%;
    transition: all 0.15s;
  }
  .search-close:hover { background: var(--color-surface); color: var(--color-primary); }

  /* ── Responsive ──────────────────────────── */
  @media (max-width: 1024px) {
    .main-nav { display: none; }
    .mobile-only { display: flex; }
  }
  @media (min-width: 1025px) {
    .mobile-only { display: none; }
    .mobile-nav { display: none !important; }
  }
  @media (max-width: 640px) {
    .logo-name { font-size: 0.95rem; }
    .logo-tagline { display: none; }
    .header-inner { padding: 0 1rem; height: 56px; }
  }
</style>
