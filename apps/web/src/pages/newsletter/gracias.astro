---
import BaseHTML from '../../layouts/BaseHTML.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---
<BaseHTML title="Suscripción confirmada — Desde el Tablón" description="Ya estás suscripto al newsletter de Desde el Tablón.">
  <Header />
  <main id="main-content" style="max-width:560px;margin:6rem auto;padding:2rem;text-align:center;">
    <div style="font-size:3rem;margin-bottom:1rem;">📬</div>
    <h1 class="font-display" style="font-size:2rem;font-weight:700;color:var(--color-text);margin-bottom:0.75rem;">¡Listo, estás adentro!</h1>
    <p style="font-family:'Lora',Georgia,serif;font-size:1.05rem;color:var(--color-text-muted);line-height:1.7;margin-bottom:2rem;">
      Cada viernes te llegan las mejores notas de la semana sobre River. Sin spam, un click para salir cuando quieras.
    </p>
    <a href="/" style="background:var(--color-primary);color:white;text-decoration:none;padding:0.85rem 2rem;border-radius:8px;font-family:'Inter',sans-serif;font-weight:600;">
      Ir al inicio →
    </a>
  </main>
  <Footer />
</BaseHTML>
