{
  "name": "@desdeeltablon/api",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "node --experimental-sqlite --import=tsx/esm src/index.ts",
    "build": "tsc",
    "start": "node --experimental-sqlite dist/index.js",
    "db:init": "node --experimental-sqlite -e \"import(\"./dist/db/index.js\").then(m => m.initDb())\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^3.0.3",
    "rss-parser": "^3.13.0",
    "slug": "^9.1.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.15.0",
    "typescript": "^5.5.0"
  }
}
