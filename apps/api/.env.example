# ══════════════════════════════════════════════════════
#  desdeeltablon.com — Variables de entorno del backend
#  Copiá este archivo como .env y completá los valores
# ══════════════════════════════════════════════════════

# ── OBLIGATORIAS (el servidor no arranca sin estas) ───
ANTHROPIC_API_KEY=sk-ant-api03-...
JWT_SECRET=un-string-largo-aleatorio-minimo-32-caracteres

# ── ADMIN (se crea al primer arranque) ────────────────
ADMIN_EMAIL=tu@email.com
ADMIN_PASSWORD=contraseña-segura-con-letras-y-numeros

# ── API EXTERNAS ──────────────────────────────────────
API_FOOTBALL_KEY=
PEXELS_API_KEY=
UNSPLASH_ACCESS_KEY=

# ── EMAIL (para newsletter cuando lo actives) ─────────
RESEND_API_KEY=
NEWSLETTER_FROM=newsletter@desdeeltablon.com

# ── CONFIG ────────────────────────────────────────────
NODE_ENV=production
PORT=3001
SITE_URL=https://desdeeltablon.com
FRONTEND_URL=https://desdeeltablon.com
ENABLE_SCHEDULER=true
DATABASE_PATH=./data/desdeeltablon.db
